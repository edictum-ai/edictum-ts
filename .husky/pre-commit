#!/bin/sh

echo "Running pre-commit checks..."

# Build
echo "→ build"
pnpm -r build || exit 1

# Lint
echo "→ lint"
pnpm -r lint || exit 1

# Format
echo "→ format"
pnpm format:check || exit 1

# Typecheck
echo "→ typecheck"
pnpm -r typecheck || exit 1

# Tests
echo "→ test"
pnpm -r test || exit 1

echo "All pre-commit checks passed."
