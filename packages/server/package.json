{
  "name": "@edictum/server",
  "version": "0.1.1",
  "description": "Server SDK (HTTP client, SSE, audit sink) for edictum",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@edictum/core": "workspace:*"
  },
  "devDependencies": {
    "@edictum/core": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "typescript-eslint": "^8.57.2"
  },
  "keywords": [
    "ai",
    "agents",
    "edictum",
    "server",
    "audit"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/edictum-ai/edictum-ts.git",
    "directory": "packages/server"
  }
}
