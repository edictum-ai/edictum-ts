{
  "name": "@edictum/openai-agents",
  "version": "0.2.1",
  "description": "OpenAI Agents SDK adapter for Edictum agency-boundary enforcement",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@edictum/core": ">=0.3.0 <0.6.0",
    "@openai/agents": ">=0.7.0"
  },
  "devDependencies": {
    "@edictum/core": "workspace:*",
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "eslint": "^10.1.0",
    "typescript-eslint": "^8.58.0"
  },
  "keywords": [
    "ai",
    "agents",
    "edictum",
    "openai-agents",
    "adapter"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/edictum-ai/edictum-ts.git",
    "directory": "packages/openai-agents"
  }
}
