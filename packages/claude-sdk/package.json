{
  "name": "@edictum/claude-sdk",
  "version": "0.1.0",
  "description": "Claude Agent SDK adapter for edictum",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@edictum/core": "workspace:*",
    "@anthropic-ai/claude-agent-sdk": ">=0.1.0"
  },
  "devDependencies": {
    "@edictum/core": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "edictum",
    "claude-sdk",
    "adapter"
  ]
}
