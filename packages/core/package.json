{
  "name": "@edictum/core",
  "version": "0.3.1",
  "description": "Runtime rule enforcement for AI agent tool calls",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist docs/api",
    "docs": "typedoc"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "tsup": "^8.0.0",
    "typedoc": "^0.28.17",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.2",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "governance",
    "safety",
    "contracts",
    "tool-calling",
    "guardrails"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/edictum-ai/edictum-ts.git",
    "directory": "packages/core"
  }
}
