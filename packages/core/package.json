{
  "name": "@edictum/core",
  "version": "0.1.0",
  "description": "Runtime contract enforcement for AI agent tool calls",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "keywords": [
    "ai",
    "agents",
    "governance",
    "safety",
    "contracts",
    "tool-calling",
    "guardrails"
  ]
}
