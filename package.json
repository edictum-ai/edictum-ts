{
  "name": "edictum-ts",
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "^1.19.10",
      "fast-xml-parser": "^5.5.6",
      "flatted": "^3.4.2",
      "protobufjs": "7.5.5"
    }
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2"
  }
}
